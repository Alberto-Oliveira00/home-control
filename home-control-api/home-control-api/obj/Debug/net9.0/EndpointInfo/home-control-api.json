  "components": {
    "schemas": {
      "CategoryType": {
        "enum": [
          1,
          2,
          3
        ],
        "type": "integer",
        "format": "int32"
      },
      "CreateCategoryDto": {
        "required": [
          "description",
          "type"
        ],
        "type": "object",
        "properties": {
          "description": {
            "maxLength": 400,
            "minLength": 0,
            "type": "string"
          },
          "type": {
            "$ref": "#/components/schemas/CategoryType"
          }
        },
        "additionalProperties": false
      },
      "CreateTransactionDto": {
        "required": [
          "categoryId",
          "description",
          "type",
          "userId",
          "value"
        ],
        "type": "object",
        "properties": {
          "description": {
            "maxLength": 400,
            "minLength": 0,
            "type": "string"
          },
          "value": {
            "minimum": 0,01,
            "type": "number",
            "format": "double"
          },
          "type": {
            "$ref": "#/components/schemas/TransactionType"
          },
          "categoryId": {
            "type": "integer",
            "format": "int32"
          },
          "userId": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "CreateUserDto": {
        "required": [
          "age",
          "name"
        ],
        "type": "object",
        "properties": {
          "name": {
            "maxLength": 200,
            "minLength": 0,
            "type": "string"
          },
          "age": {
            "maximum": 150,
            "minimum": 0,
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "TransactionType": {
        "enum": [
          1,
          2
        ],
        "type": "integer",
        "format": "int32"
      },
      "UpdateUserDto": {
        "required": [
          "age",
          "name"
        ],
        "type": "object",
        "properties": {
          "name": {
            "maxLength": 200,
            "minLength": 0,
            "type": "string"
          },
          "age": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      }
    }
